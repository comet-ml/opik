<clickhouse>
    <!-- Read-only sandbox profile for the Agent Insights free-form SQL user. Lives in the users config (users.d) so it
         is registered in the access-control storage and can be attached via SQL `CREATE USER ... SETTINGS PROFILE`.
         The static limits live here; the user, GRANTs and restrictive row policies are SQL-managed RBAC (see
         provisionReadOnlyUser in AnalyticsQueriesResourceTest). The SQL_workspace_id / SQL_project_id custom settings
         are CHANGEABLE_IN_READONLY so the bounds can be pushed as server settings despite readonly = 1. -->
    <profiles>
        <comet_llm_readonly_freeform_sql_profile>
            <readonly>1</readonly>
            <max_execution_time>180</max_execution_time>
            <max_result_rows>100000</max_result_rows>
            <result_overflow_mode>throw</result_overflow_mode>
            <max_rows_to_read>100000000</max_rows_to_read>
            <read_overflow_mode>throw</read_overflow_mode>
            <SQL_workspace_id>''</SQL_workspace_id>
            <SQL_project_id>''</SQL_project_id>
            <constraints>
                <SQL_workspace_id><changeable_in_readonly/></SQL_workspace_id>
                <SQL_project_id><changeable_in_readonly/></SQL_project_id>
            </constraints>
        </comet_llm_readonly_freeform_sql_profile>
    </profiles>
</clickhouse>

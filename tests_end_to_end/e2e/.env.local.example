# Local (OSS) Opik environment — no auth, default workspace.
# Copy this to .env or export these vars before running `npx playwright test`.

OPIK_DEPLOYMENT=oss
OPIK_BASE_URL=http://localhost:5174

# Everything below is optional for local OSS runs:
# - OPIK_WORKSPACE defaults to 'default' for OSS
# - OPIK_TEST_USER_NAME / EMAIL / PASSWORD: not required (no auth wall)
# - OPIK_API_KEY: not required (OSS accepts unauthenticated REST)

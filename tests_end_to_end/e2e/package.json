{
  "name": "@opik/e2e",
  "version": "0.0.1",
  "private": true,
  "description": "Opik 2.0 E2E test suite",
  "scripts": {
    "test": "playwright test",
    "test:t1": "playwright test --grep @t1-smoke",
    "test:t2": "playwright test --grep @t2-cuj",
    "test:t3": "playwright test --grep @t3-nightly",
    "test:feature": "playwright test --grep",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "codegen": "playwright codegen",
    "report": "playwright show-report",
    "backend:generate": "openapi-typescript http://localhost:8080/openapi.json -o core/backend/generated/schema.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "openapi-fetch": "^0.13.0",
    "openapi-typescript": "^7.4.0",
    "typescript": "^5.6.0"
  }
}
